@inherits LayoutComponentBase

<div class="app-wrapper">
    <header>
        <div class="container-fluid d-flex align-items-center">

            <NavLink href="/" class="navbar-brand fw-bold me-4">
                🧺 QuickBasket
            </NavLink>

            <NavLink href="/app/products" class="nav-link me-auto">
                Products
            </NavLink>

            <form class="d-flex me-3">
                <input class="form-control" type="search" placeholder="Search..." />
            </form>

            <NavLink href="/app/cart" class="btn btn-outline-dark">
                🛒 (0)
            </NavLink>

        </div>
    </header>

    <main class="main-content"> 
        @Body
    </main>

    <footer class="footer">
        <div class="container">

            <div class="footer-grid">

                <div class="footer-box">
                    <h5>🧺 QuickBasket</h5>
                    <p>Fresh groceries delivered fast to your doorstep.</p>
                </div>

                <div class="footer-box">
                    <h6>Quick Links</h6>
                    <NavLink href="/">Home</NavLink>
                    <NavLink href="/app/products">Products</NavLink>
                    <NavLink href="/cart">Cart</NavLink>
                </div>

                <div class="footer-box">
                    <h6>Contact</h6>
                    <p>📍 Dhaka, Bangladesh</p>
                    <p>📞 +880 123 456 789</p>
                    <p>✉ support@quickbasket.com</p>
                </div>

            </div>

            <hr />

            <div class="footer-bottom">
                © 2025 QuickBasket. All rights reserved.
            </div>

        </div>
    </footer>
</div>