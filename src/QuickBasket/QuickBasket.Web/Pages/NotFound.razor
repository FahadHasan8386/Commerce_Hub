        <div class="product-card">
            <img src="https://via.placeholder.com/200" alt="Product">
            <h3>Fresh Apple</h3>
            <p class="price">$2.99 / kg</p>
            <button class="btn-add">Add to Cart</button>
        </div>

        <!-- Product Card 2 -->
        <div class="product-card">
            <img src="https://via.placeholder.com/200" alt="Product">
