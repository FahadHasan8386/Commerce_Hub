        <!-- Product Card 3 -->
        <div class="product-card">
            <img src="https://via.placeholder.com/200" alt="Product">
            <h3>Fresh Bread</h3>
            <p class="price">$1.20</p>
            <button class="btn-add">Add to Cart</button>
        </div>

        <!-- Product Card 4 -->
        <div class="product-card">
            <img src="https://via.placeholder.com/200" alt="Product">
            <h3>Orange Juice</h3>
            <p class="price">$3.00</p>
            <button class="btn-add">Add to Cart</button>
        </div>

