@page "/app/home"
  
<PageTitle>Home</PageTitle>

<!-- Hero Section -->
<div class="hero-section">
    <div class="container text-center">
        <h1>Welcome to eCommerce Store</h1>
        <p class="lead mb-4">Discover amazing products at unbeatable prices</p>
        <a href="/Products" class="btn btn-light btn-lg">Shop Now</a>
    </div>
</div>

<div class="container">
    <!-- Featured Categories -->
    <div class="row mb-5">
        <div class="col-12 text-center mb-4">
            <h2>Shop by Category</h2>
            <p class="text-muted">Browse our wide range of products</p>
        </div>
        
        <div class="col-md-4 mb-4">
            <div class="card text-center category-card">
                <div class="card-body">
                    <i class="fas fa-laptop fa-3x text-primary mb-3"></i>
                    <h4>Electronics</h4>
                    <p>Latest gadgets and devices</p>
                    <a href="/Products?categoryId=1" class="btn btn-outline-primary">Shop Now</a>
                </div>
            </div>
        </div>
        
        <div class="col-md-4 mb-4">
            <div class="card text-center category-card">
                <div class="card-body">
                    <i class="fas fa-tshirt fa-3x text-success mb-3"></i>
                    <h4>Fashion</h4>
                    <p>Trendy clothing and accessories</p>
                    <a href="/Products?categoryId=2" class="btn btn-outline-primary">Shop Now</a>
                </div>
            </div>
        </div>
        
        <div class="col-md-4 mb-4">
            <div class="card text-center category-card">
                <div class="card-body">
                    <i class="fas fa-book fa-3x text-info mb-3"></i>
                    <h4>Books</h4>
                    <p>Best-selling books</p>
                    <a href="/Products?categoryId=3" class="btn btn-outline-primary">Shop Now</a>
                </div>
            </div>
        </div>
    </div>

    <!-- Featured Products -->
    <div class="row">
        <div class="col-12 text-center mb-4">
            <h2>Featured Products</h2>
            <p class="text-muted">Check out our most popular items</p>
        </div>
        
        @* Products will be loaded dynamically *@
        <div id="featuredProducts" class="row"></div>
    </div>
</div>