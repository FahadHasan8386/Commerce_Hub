@page "/app/home"

@inject ProductApiService ProductService
<PageTitle>QuickBasket</PageTitle>

<div class="hero-section">

    <div class="hero-content">

        <span class="tagline">
            🛍️ Trusted Online Shopping Platform
        </span>

        <h1>
            Discover Amazing Products Everyday
        </h1>

        <p>
            Shop electronics, fashion, groceries, accessories and more
            with secure payment, fast delivery and best quality products
            at affordable prices.
        </p>

        <div class="hero-buttons">

            <button class="shop-btn">
                Explore Products
            </button>

            <button class="offer-btn">
                Today's Deals
            </button>

        </div>

    </div>

    <div class="hero-image">

        <img src="https://images.unsplash.com/photo-1607082348824-0a96f2a4b9da?q=80&w=1200&auto=format&fit=crop"
             alt="Ecommerce">

    </div>

</div>



<div class="feature-section">

    <div class="feature-card">
        <h3>🚚 Fast Delivery</h3>
        <p>
            Quick and reliable delivery service across the country.
        </p>
    </div>

    <div class="feature-card">
        <h3>🛒 Premium Products</h3>
        <p>
            High quality products from trusted brands and sellers.
        </p>
    </div>

    <div class="feature-card">
        <h3>💳 Secure Payment</h3>
        <p>
            Safe online payment with cash on delivery support.
        </p>
    </div>

    <div class="feature-card">
        <h3>🔥 Best Deals</h3>
        <p>
            Daily discounts and special offers on popular items.
        </p>
    </div>

</div>


<div class="product-section">

    <div class="section-header">
        <h2>Popular Products</h2>

        @if (products != null)
        {
            <span class="product-count">
                @products.Count Products
            </span>
        }
    </div>

    @if (products == null)
    {
        <div class="loading-text">
            Loading products...
        </div>
    }
    else if (!products.Any())
    {
        <div class="empty-product">
            No Products Found
        </div>
    }
    else
    {
        <div class="product-grid">

            @foreach (var product in products)
            {
                <div class="product-card">

                    <div class="product-image">

                        @if (product.Images.Any())
                        {
                            <img src="@product.Images[0].ImageUrl"
                                 alt="@product.Name" />
                        }
                        else
                        {
                            <img src="https://via.placeholder.com/300x220?text=No+Image"
                                 alt="No Image" />
                        }

                        @if (product.StockQuantity == 0)
                        {
                            <span class="stock out-stock">
                                Out Of Stock
                            </span>
                        }
                        else if (product.StockQuantity <= 5)
                        {
                            <span class="stock low-stock">
                                Only @product.StockQuantity Left
                            </span>
                        }
                        else
                        {
                            <span class="stock in-stock">
                                In Stock
                            </span>
                        }

                    </div>

                    <div class="product-info">

                        <h4>@product.Name</h4>

                        <p class="description">
                            @product.Description
                        </p>

                        <div class="product-footer">

                            <span class="price">
                                ৳@product.Price.ToString("N0")
                            </span>

                            <button class="cart-btn"
                                    disabled="@(product.StockQuantity == 0)">
                                Add To Cart
                            </button>

                        </div>

                    </div>

                </div>
            }

        </div>
    }

</div>

@code {

    private List<ProductResponseDto>? products;

    protected override async Task OnInitializedAsync()
    {
        products = await ProductService.GetAllProductsAsync();
    }

}

<style>

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
        font-family: Arial, Helvetica, sans-serif;
    }

    body {
        background: #f5f7fa;
    }

    .hero-section {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 40px;
        padding: 60px 8%;
        background: linear-gradient(to right,#0f9b0f,#38ef7d);
        color: white;
        border-radius: 20px;
        margin-top: 20px;
        flex-wrap: wrap;
    }

    .hero-content {
        flex: 1;
        min-width: 300px;
    }

    .tagline {
        background: white;
        color: #0f9b0f;
        padding: 8px 15px;
        border-radius: 30px;
        font-size: 14px;
        font-weight: bold;
        display: inline-block;
        margin-bottom: 20px;
    }

    .hero-content h1 {
        font-size: 55px;
        margin-bottom: 20px;
    }

    .hero-content p {
        font-size: 18px;
        line-height: 1.7;
        margin-bottom: 30px;
        max-width: 550px;
    }

    .hero-buttons {
        display: flex;
        gap: 15px;
    }

    .shop-btn,
    .offer-btn {
        padding: 14px 28px;
        border: none;
        border-radius: 10px;
        font-size: 16px;
        cursor: pointer;
        transition: .3s;
        font-weight: bold;
    }

    .shop-btn {
        background: white;
        color: #0f9b0f;
    }

    .offer-btn {
        background: transparent;
        border: 2px solid white;
        color: white;
    }

    .shop-btn:hover {
        transform: translateY(-3px);
    }

    .offer-btn:hover {
        background: white;
        color: #0f9b0f;
    }

    .hero-image {
        flex: 1;
        text-align: center;
    }

        .hero-image img {
            width: 100%;
            max-width: 500px;
            border-radius: 20px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.2);
        }

    .feature-section {
        display: grid;
        grid-template-columns: repeat(auto-fit,minmax(250px,1fr));
        gap: 20px;
        margin-top: 40px;
    }

    .feature-card {
        background: white;
        padding: 30px;
        border-radius: 15px;
        text-align: center;
        box-shadow: 0 5px 15px rgba(0,0,0,0.08);
        transition: .3s;
    }

        .feature-card:hover {
            transform: translateY(-5px);
        }

        .feature-card h3 {
            margin-bottom: 15px;
            color: #0f9b0f;
        }

    .product-section {
        margin-top: 60px;
    }

        .product-section h2 {
            text-align: center;
            margin-bottom: 30px;
            font-size: 35px;
            color: #222;
        }

    .product-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit,minmax(250px,1fr));
        gap: 25px;
    }

    .product-card {
        background: white;
        padding: 20px;
        border-radius: 18px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.08);
        text-align: center;
        transition: .3s;
    }

        .product-card:hover {
            transform: translateY(-5px);
        }

        .product-card img {
            width: 100%;
            height: 220px;
            object-fit: cover;
            border-radius: 12px;
            margin-bottom: 15px;
        }

        .product-card h4 {
            margin-bottom: 10px;
            font-size: 22px;
        }

        .product-card p {
            color: #0f9b0f;
            font-size: 18px;
            font-weight: bold;
            margin-bottom: 15px;
        }

        .product-card button {
            background: #0f9b0f;
            color: white;
            border: none;
            padding: 12px 20px;
            border-radius: 10px;
            cursor: pointer;
            font-weight: bold;
            transition: .3s;
        }

            .product-card button:hover {
                background: #087f08;
            }

</style>