@page "/app/products"
@inject ProductApiService ProductService

<style>
    .products-page {
        max-width: 1000px;
        margin: auto;
        padding: 20px;
        background: #f5f5f5;
        font-family: sans-serif;
    }

    .page-header {
        margin-bottom: 20px;
    }

        .page-header h2 {
            font-size: 28px;
            color: #222;
        }


    /* Card */
    .card {
        background: white;
        border-radius: 8px;
        overflow: hidden;
        border: 1px solid #ddd;
        transition: 0.2s;
    }

        .card:hover {
            transform: translateY(-4px);
        }

    /* Image */
    .img-wrap img {
        width: 100%;
        height: 180px;
        object-fit: cover;
        display: block;
    }

    /* Body */
    .card-body {
        padding: 15px;
    }

    .product-name {
        font-size: 18px;
        margin-bottom: 8px;
        color: #222;
    }

    .product-desc {
        font-size: 14px;
        color: #666;
        margin-bottom: 12px;
    }

    .card-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .price {
        font-weight: bold;
        color: #000;
    }

  
</style>

<div class="products-page">
    <div class="page-header">
        <h2>Our Products</h2>
        @if (products != null)
        {
            <span class="badge-count">@products.Count items</span>
        }
    </div>

    @if (products == null)
    {
        <div class="loading-grid">
            @for (int i = 0; i < 6; i++)
            {
                <div class="card skeleton">
                    <div class="img-wrap skeleton-img"></div>
                    <div class="card-body">
                        <div class="skeleton-line short"></div>
                        <div class="skeleton-line"></div>
                        <div class="skeleton-line medium"></div>
                    </div>
                </div>
            }
        </div>
    }
    else if (!products.Any())
    {
        <div class="empty-state">
            <i class="ti ti-mood-empty"></i>
            <p>No products found</p>
        </div>
    }
    else
    {
        <div class="product-grid">
            @foreach (var product in products)
            {
                <div class="card">
                    <div class="img-wrap">
                        @if (product.Images.Any())
                        {
                            <img src="@product.Images[0].ImageUrl" alt="@product.Name" loading="lazy" />
                        }
                        else
                        {
                            <div class="img-placeholder">
                                <i class="ti ti-photo"></i>
                                <span>No image</span>
                            </div>
                        }

                        @if (product.StockQuantity == 0)
                        {
                            <span class="stock-badge out">Out of stock</span>
                        }
                        else if (product.StockQuantity <= 5)
                        {
                            <span class="stock-badge low">Only @product.StockQuantity left</span>
                        }
                        else
                        {
                            <span class="stock-badge in">Stock: @product.StockQuantity</span>
                        }
                    </div>

                    <div class="card-body">
                        <p class="product-name">@product.Name</p>
                        <p class="product-desc">@product.Description</p>
                        <div class="card-footer">
                            <span class="price">৳@product.Price.ToString("N0")</span>
                            <button class="btn-add" disabled="@(product.StockQuantity == 0)">
                                <i class="ti ti-shopping-cart"></i> Add
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<ProductResponseDto>? products;

    protected override async Task OnInitializedAsync()
    {
        products = await ProductService.GetAllProductsAsync();
    }
}