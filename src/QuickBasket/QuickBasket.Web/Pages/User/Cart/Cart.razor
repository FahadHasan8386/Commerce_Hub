@page "/cart"

@using QuickBasket.Application.Features.CartItems.DTOs
@inject CartApiService CartService

<PageTitle>Shopping Cart</PageTitle>

<div class="container">

    <h1>🛒 My Cart</h1>

    @if (isLoading)
    {
        <p>Loading cart...</p>
    }
    else if (!cartItems.Any())
    {
        <div class="empty-cart">
            <h3>Your cart is empty</h3>
        </div>
    }
    else
    {
        @foreach (var item in cartItems)
        {
            <div class="cart-item">

                <img src="@(string.IsNullOrWhiteSpace(item.ProductImageUrl)
                                         ? "https://via.placeholder.com/100"
                                         : item.ProductImageUrl)"
                     alt="@item.ProductName" />

                <div class="details">
                    <h4>@item.ProductName</h4>

                    <p class="category">
                        @item.CategoryName
                    </p>

                    <p>
                        Unit Price: ৳@item.UnitPrice
                    </p>
                </div>

                <div class="qty-section">

                    <button @onclick="() => DecreaseQty(item)">
                        -
                    </button>

                    <span>@item.Quantity</span>

                    <button @onclick="() => IncreaseQty(item)">
                        +
                    </button>

                </div>

                <div class="total-price">
                    ৳@item.TotalPrice
                </div>

                <button class="remove-btn"
                        @onclick="() => RemoveItem(item.Id)">
                    🗑
                </button>

            </div>
        }

        <hr />

        <div class="summary">

            <h3>Order Summary</h3>

            <p>
                Subtotal:
                <strong>৳@SubTotal</strong>
            </p>

            <p>
                Delivery:
                <strong>৳@DeliveryCharge</strong>
            </p>

            <h2>
                Total:
                ৳@(SubTotal + DeliveryCharge)
            </h2>

            <button class="checkout-btn">
                Proceed To Checkout
            </button>

        </div>
    }

</div>

@code {

    private List<CartItemResponseDto> cartItems = new();

    private bool isLoading = true;

    // Demo Cart Id
    private int CartId = 1;

    protected override async Task OnInitializedAsync()
    {
        await LoadCart();
    }

    private async Task LoadCart()
    {
        isLoading = true;

        cartItems = await CartService.GetCartItemsByCartIdAsync(CartId);

        isLoading = false;
    }

    private async Task IncreaseQty(CartItemResponseDto item)
    {
        item.Quantity++;

        // API call add later
        // await CartService.UpdateCartItemAsync(...);

        StateHasChanged();
    }

    private async Task DecreaseQty(CartItemResponseDto item)
    {
        if (item.Quantity <= 1)
            return;

        item.Quantity--;

        // API call add later
        // await CartService.UpdateCartItemAsync(...);

        StateHasChanged();
    }

    private async Task RemoveItem(int id)
    {
        // await CartService.DeleteCartItemAsync(id);

        cartItems.RemoveAll(x => x.Id == id);

        StateHasChanged();
    }

    private decimal SubTotal =>
        cartItems.Sum(x => x.TotalPrice);

    private decimal DeliveryCharge =>
        cartItems.Any() ? 80 : 0;
}

<style>
    .container {
        max-width: 1100px;
        margin: auto;
        padding: 20px;
    }

    .cart-item {
        display: flex;
        align-items: center;
        gap: 20px;
        background: white;
        padding: 15px;
        margin-bottom: 15px;
        border-radius: 12px;
        box-shadow: 0 2px 10px rgba(0,0,0,.08);
    }

        .cart-item img {
            width: 100px;
            height: 100px;
            object-fit: cover;
            border-radius: 10px;
        }

    .details {
        flex: 1;
    }

        .details h4 {
            margin: 0 0 5px;
        }

    .category {
        color: gray;
        font-size: 14px;
    }

    .qty-section {
        display: flex;
        align-items: center;
        gap: 10px;
    }

        .qty-section button {
            width: 35px;
            height: 35px;
            border: none;
            cursor: pointer;
            border-radius: 8px;
        }

    .total-price {
        min-width: 120px;
        text-align: center;
        font-weight: bold;
    }

    .remove-btn {
        border: none;
        background: crimson;
        color: white;
        width: 40px;
        height: 40px;
        border-radius: 8px;
        cursor: pointer;
    }

    .summary {
        margin-top: 25px;
        padding: 20px;
        background: white;
        border-radius: 12px;
        box-shadow: 0 2px 10px rgba(0,0,0,.08);
    }

    .checkout-btn {
        width: 100%;
        padding: 12px;
        border: none;
        background: #0d6efd;
        color: white;
        border-radius: 10px;
        cursor: pointer;
    }
</style>