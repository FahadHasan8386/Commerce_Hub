@page "/app/cart"

<div class="cart-page">

    <!-- PAGE HEADER -->
    <div class="cart-header">
        <div>
            <h1>🛒 Shopping Cart</h1>
            <p>Your selected products ready for checkout</p>
        </div>

        <span class="cart-count">
            3 Items
        </span>
    </div>

    <div class="cart-layout">

        <!-- LEFT SIDE -->
        <div class="cart-items">

            <!-- ITEM -->
            <div class="cart-item">

                <img src="https://images.unsplash.com/photo-1542838132-92c53300491e"
                     alt="Product" />

                <div class="item-details">
                    <h3>Fresh Vegetables Pack</h3>
                    <p>Organic farm fresh vegetables</p>

                    <div class="qty-box">
                        <button>-</button>
                        <span>1</span>
                        <button>+</button>
                    </div>
                </div>

                <div class="item-price">
                    <h4>$12.99</h4>
                    <button class="remove-btn">
                        Remove
                    </button>
                </div>

            </div>

            <!-- ITEM -->
            <div class="cart-item">

                <img src="https://images.unsplash.com/photo-1580910051074-3eb694886505"
                     alt="Product" />

                <div class="item-details">
                    <h3>Fresh Fruits Basket</h3>
                    <p>Mixed seasonal fruits</p>

                    <div class="qty-box">
                        <button>-</button>
                        <span>2</span>
                        <button>+</button>
                    </div>
                </div>

                <div class="item-price">
                    <h4>$18.50</h4>
                    <button class="remove-btn">
                        Remove
                    </button>
                </div>

            </div>

            <!-- ITEM -->
            <div class="cart-item">

                <img src="https://images.unsplash.com/photo-1576186726115-4d51596775d1"
                     alt="Product" />

                <div class="item-details">
                    <h3>Snacks Combo Pack</h3>
                    <p>Chips & cookies combo</p>

                    <div class="qty-box">
                        <button>-</button>
                        <span>1</span>
                        <button>+</button>
                    </div>
                </div>

                <div class="item-price">
                    <h4>$9.99</h4>
                    <button class="remove-btn">
                        Remove
                    </button>
                </div>

            </div>

        </div>

        <!-- RIGHT SIDE -->
        <div class="summary-card">

            <h2>Order Summary</h2>

            <div class="summary-row">
                <span>Subtotal</span>
                <span>$41.48</span>
            </div>

            <div class="summary-row">
                <span>Delivery</span>
                <span>$5.00</span>
            </div>

            <div class="summary-row">
                <span>Discount</span>
                <span>- $3.00</span>
            </div>

            <hr />

            <div class="summary-total">
                <span>Total</span>
                <span>$43.48</span>
            </div>

            <button class="checkout-btn">
                Proceed To Checkout
            </button>

        </div>

    </div>

</div>

<style>

    .cart-page {
        padding: 40px;
        background: #f5f7fb;
        min-height: 100vh;
    }

    .cart-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
    }

        .cart-header h1 {
            margin: 0;
            font-size: 38px;
            font-weight: 800;
            color: #1f2937;
        }

        .cart-header p {
            color: #6b7280;
            margin-top: 5px;
        }

    .cart-count {
        background: #111827;
        color: white;
        padding: 10px 18px;
        border-radius: 30px;
        font-weight: 600;
    }

    .cart-layout {
        display: grid;
        grid-template-columns: 2fr 1fr;
        gap: 30px;
    }

    .cart-items {
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    .cart-item {
        background: white;
        border-radius: 20px;
        padding: 20px;
        display: flex;
        align-items: center;
        gap: 20px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.05);
    }

        .cart-item img {
            width: 120px;
            height: 120px;
            object-fit: cover;
            border-radius: 16px;
        }

    .item-details {
        flex: 1;
    }

        .item-details h3 {
            margin: 0;
            font-size: 22px;
            color: #111827;
        }

        .item-details p {
            color: #6b7280;
            margin: 8px 0 20px;
        }

    .qty-box {
        display: flex;
        align-items: center;
        gap: 12px;
    }

        .qty-box button {
            width: 35px;
            height: 35px;
            border: none;
            border-radius: 10px;
            background: #111827;
            color: white;
            font-size: 18px;
            cursor: pointer;
        }

        .qty-box span {
            font-weight: 700;
            font-size: 18px;
        }

    .item-price {
        text-align: right;
    }

        .item-price h4 {
            font-size: 24px;
            margin-bottom: 15px;
            color: #111827;
        }

    .remove-btn {
        border: none;
        background: #ef4444;
        color: white;
        padding: 10px 16px;
        border-radius: 10px;
        cursor: pointer;
        font-weight: 600;
    }

    .summary-card {
        background: white;
        border-radius: 20px;
        padding: 30px;
        height: fit-content;
        box-shadow: 0 10px 25px rgba(0,0,0,0.05);
        position: sticky;
        top: 20px;
    }

        .summary-card h2 {
            margin-bottom: 25px;
            color: #111827;
        }

    .summary-row {
        display: flex;
        justify-content: space-between;
        margin-bottom: 18px;
        color: #4b5563;
        font-size: 17px;
    }

    .summary-total {
        display: flex;
        justify-content: space-between;
        margin-top: 20px;
        font-size: 24px;
        font-weight: 800;
        color: #111827;
    }

    .checkout-btn {
        width: 100%;
        margin-top: 25px;
        padding: 16px;
        border: none;
        border-radius: 14px;
        background: #16a34a;
        color: white;
        font-size: 18px;
        font-weight: 700;
        cursor: pointer;
        transition: 0.3s;
    }

        .checkout-btn:hover {
            transform: translateY(-2px);
            background: #15803d;
        }

    @@media(max-width:900px) {

        .cart-layout {
            grid-template-columns: 1fr;
        }

        .cart-item {
            flex-direction: column;
            align-items: flex-start;
        }

        .item-price {
            width: 100%;
            text-align: left;
        }
    }

</style>