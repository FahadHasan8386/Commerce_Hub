@page "/app/cart"

@using QuickBasket.Application.Features.Carts.DTOs
@using QuickBasket.Application.Features.CartItems.DTOs

@inject CartApiService CartApiService

<div class="cart-container">

    <div class="cart-header">
        <div>
            <h1>🛒 Shopping Cart</h1>
            <p>Your selected products ready for checkout</p>
        </div>

        <span class="cart-count">
            @(CurrentCart?.Items.Sum(x => x.Quantity) ?? 0) Items
        </span>
    </div>

    @if (isLoading)
    {
        <h4>Loading cart...</h4>
    }
    else if (CurrentCart == null || !CurrentCart.Items.Any())
    {
        <div class="empty-cart">
            <h3>Your cart is empty!</h3>
            <p>No products found.</p>
        </div>
    }
    else
    {
        <div class="cart-content">

            <div class="cart-items-list">

                @foreach (var item in CurrentCart.Items)
                {
                    <div class="cart-item">

                        <div class="product-details">
                            <h3>Product #@item.ProductId</h3>
                            <p>$@item.UnitPrice each</p>
                        </div>

                        <div class="quantity-selectors">
                            <button @onclick="() => DecreaseQty(item)">-</button>

                            <span>@item.Quantity</span>

                            <button @onclick="() => IncreaseQty(item)">+</button>
                        </div>

                        <div class="item-total-section">

                            <span class="item-total">
                                $@(item.UnitPrice * item.Quantity)
                            </span>

                            <button class="remove-btn"
                                    @onclick="() => RemoveItem(item)">
                                Remove
                            </button>

                        </div>

                    </div>
                }

            </div>

            <div class="cart-summary">

                <h2>Order Summary</h2>

                <div class="summary-row">
                    <span>Subtotal</span>
                    <span>$@CalculateSubtotal()</span>
                </div>

                <div class="summary-row">
                    <span>Shipping</span>
                    <span>Free</span>
                </div>

                <hr />

                <div class="summary-row total-row">
                    <span>Total</span>
                    <span>$@CalculateSubtotal()</span>
                </div>

                <button class="checkout-btn">
                    Proceed to Checkout 🚀
                </button>

            </div>

        </div>
    }

</div>

@code {

    private List<CartResponseDto> carts = new();

    private CartResponseDto? CurrentCart;

    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            carts = await CartApiService.GetAllCartsAsync();

            CurrentCart = carts
                .FirstOrDefault(x => !x.IsCheckedOut);
        }
        finally
        {
            isLoading = false;
        }
    }

    private decimal CalculateSubtotal()
    {
        if (CurrentCart == null)
            return 0;

        return CurrentCart.Items.Sum(x =>
            x.UnitPrice * x.Quantity);
    }

    private void IncreaseQty(CartItemResponseDto item)
    {
        item.Quantity++;
    }

    private void DecreaseQty(CartItemResponseDto item)
    {
        if (item.Quantity > 1)
            item.Quantity--;
    }

    private void RemoveItem(CartItemResponseDto item)
    {
        CurrentCart?.Items.Remove(item);
    }
}