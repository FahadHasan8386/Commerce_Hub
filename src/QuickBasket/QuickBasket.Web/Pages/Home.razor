@page "/app/home"
  
<PageTitle>Home</PageTitle>

<div class="row">
	<div class="col-12">
		<div class="row">
			<div class="col-12 col-md-6">
				<h1 class="fw-bold">Expense Management System</h1>
				<p class="text-muted">A true tracking of daily financial activities</p>
			</div>
			<div class="col-12 col-md-6">
				<div class="hero-button-gap">
					<button type="button" class="btn btn-outline-info rm-btn-focus" data-bs-toggle="modal" data-bs-target="#invoiceModal">
						<i class="bi bi-search"></i> Query
					</button>
					<button type="button" class="btn btn-outline-success rm-btn-focus" data-bs-toggle="modal" data-bs-target="#depositModal">
						<i class="bi bi-arrow-up-square"></i> Deposit
					</button>
					<button type="button" class="btn btn-outline-warning rm-btn-focus" data-bs-toggle="modal" data-bs-target="#expenseModal">
						<i class="bi bi-arrow-down-square"></i> Expense
					</button>
				</div>
			</div>
		</div>
	</div>
</div>
